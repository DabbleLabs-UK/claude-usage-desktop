<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>ClaudeUsage</RootNamespace>
    <AssemblyName>ClaudeUsage</AssemblyName>
    <ApplicationIcon>design\logo_icon.ico</ApplicationIcon>
    <Version>0.1.8</Version>
    <AssemblyVersion>0.1.8.0</AssemblyVersion>
    <FileVersion>0.1.8.0</FileVersion>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <!-- UseWindowsForms adds a global implicit 'using System.Windows.Forms' which
       conflicts with System.Windows.Application. Remove it; App.xaml.cs uses a
       manual 'using WinForms = System.Windows.Forms' alias instead. -->
  <ItemGroup>
    <Using Remove="System.Windows.Forms" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.*" />
  </ItemGroup>

  <ItemGroup>
    <!-- Shared DabbleLabs WPF About control (sibling checkout; same source-dependency pattern as the
         Android dabblelabs-common includeBuild). Shown in a popup AboutWindow from the toolbar. -->
    <ProjectReference Include="..\dl-wpf-about-common\DabbleLabs.Wpf.About\DabbleLabs.Wpf.About.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Update="wwwroot\**">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <Resource Include="design\logo_icon.png" />
  </ItemGroup>
</Project>
